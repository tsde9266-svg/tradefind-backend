generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  worker
  admin
}

enum WorkerStatus {
  pending
  approved
  blocked
}

enum NotificationType {
  new_review
  account_approved
  profile_saved
  call_received
  job_request
  job_accepted
  job_declined
  job_started
  job_completed
}

enum JobType {
  in_app
  call
}

enum JobStatus {
  pending
  call_pending
  accepted
  started
  completed
  declined
  cancelled
}

model User {
  id           String  @id @default(uuid())
  role         Role    @default(customer)
  name         String
  email        String  @unique
  phone        String?  // optional — social auth users may not have one
  passwordHash String?  // null for Google/Apple sign-in users
  avatarUrl    String?
  pushToken    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workerProfile  WorkerProfile?
  reviewsGiven   Review[]       @relation("ReviewsGiven")
  savedWorkers   SavedWorker[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  jobsAsCustomer JobRequest[]   @relation("CustomerJobs")

  @@index([email])
}

model WorkerProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades           String[]
  bio              String       @default("")
  pricingNotes     String       @default("")
  certifications   String[]
  serviceAreaMiles Int          @default(10)
  portfolioPhotos  String[]
  isAvailable      Boolean      @default(false)
  latitude         Float?
  longitude        Float?
  rating           Float        @default(0)
  reviewCount      Int          @default(0)
  status           WorkerStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewsReceived Review[]        @relation("ReviewsReceived")
  locationHistory LocationHistory[]
  jobsAsWorker    JobRequest[]    @relation("WorkerJobs")

  @@index([status])
  @@index([isAvailable])
  @@index([rating])
  @@index([latitude, longitude])
  @@index([userId])
}

model Review {
  id           String        @id @default(uuid())
  fromUserId   String
  fromUser     User          @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toWorkerId   String
  toWorker     WorkerProfile @relation("ReviewsReceived", fields: [toWorkerId], references: [id])
  rating       Int
  text         String
  photos       String[]
  reply        String?
  reported     Boolean       @default(false)
  reportReason String?
  removed      Boolean       @default(false)

  createdAt DateTime @default(now())

  @@index([toWorkerId])
  @@index([toWorkerId, createdAt(sort: Desc)])
  @@index([fromUserId])
  @@index([fromUserId, toWorkerId])
  @@index([reported])
}

model SavedWorker {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workerId String

  createdAt DateTime @default(now())

  @@unique([userId, workerId])
  @@index([userId])
}

model Notification {
  id     String           @id @default(uuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  title  String
  body   String
  read   Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([type])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model JobRequest {
  id          String    @id @default(uuid())
  customerId  String
  workerId    String
  type        JobType   @default(in_app)
  description String?
  status      JobStatus @default(pending)

  customer    User          @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  worker      WorkerProfile @relation("WorkerJobs", fields: [workerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId, status])
  @@index([customerId, workerId])
  @@index([workerId, status])
}

model LocationHistory {
  id        String        @id @default(uuid())
  workerId  String
  worker    WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float

  createdAt DateTime @default(now())

  @@index([workerId, createdAt])
}
